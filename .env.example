# Admin account seeded on startup. Change both before exposing the app.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-now

# Internal container path for the SQLite database file.
DATABASE_PATH=/data/kinopio-selfhost.sqlite

# Public origin used for generated links and asset URLs.
# Example: https://kinopio.example.com
VITE_PUBLIC_APP_ORIGIN=

# Keep self-host mode enabled.
VITE_SELFHOST=true

# Optional API host override for reverse proxies. Usually leave blank.
VITE_API_HOST=
